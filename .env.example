# ── Steam API ─────────────────────────────────────────────────────────────────
# Get your free key at: https://steamcommunity.com/dev/apikey
# Required — the app will warn at startup if this is missing.
STEAM_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
# Address and port the server listens on.
# Use 127.0.0.1 to restrict access to this machine only (default).
# Use 0.0.0.0 to accept connections from other machines on the network.
HOST=127.0.0.1
PORT=3000

# ── Limits ─────────────────────────────────────────────────────────────────────
# Maximum number of Steam users per search request.
MAX_USERS=10

# ── Cache ──────────────────────────────────────────────────────────────────────
# How long to cache each data type before re-fetching. The cache survives
# restarts (stored in cache.json). Delete that file to force a full refresh.
#
# Owned game libraries and player profiles — refreshed relatively often
# since users can buy new games or change their display name.
CACHE_TTL_MINUTES=60
#
# Game details (Steam rating, HLTB times) — these barely change, so a long
# TTL avoids hammering the Steam review API and HowLongToBeat on every run.
# Default: 7 days (10080 minutes).
DETAILS_CACHE_TTL_MINUTES=10080
