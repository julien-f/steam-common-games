# ── Steam API ─────────────────────────────────────────────────────────────────
# Required — the app will not start without this.
# Get your free key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
# Address and port the server listens on.
# Use 127.0.0.1 to restrict access to this machine only.
# Use 0.0.0.0 to accept connections from other machines on the network.
HOST=127.0.0.1
PORT=3000
#
# Express "trust proxy" setting — set this when running behind a reverse proxy
# (nginx, Caddy, etc.) so that rate limiting uses the real client IP from
# X-Forwarded-For rather than the proxy's address.
# Accepts: a number of hops (1), a comma-separated list of trusted IPs/CIDRs,
# or "true"/"false". Leave unset to keep Express's default (untrusted).
# See: https://expressjs.com/en/guide/behind-proxies.html
#TRUST_PROXY=1

# ── Limits ─────────────────────────────────────────────────────────────────────
# Maximum number of Steam users per search request.
MAX_USERS=10

# Per-IP rate limits (requests per minute). Searches each trigger Steam library
# fetches, so they are limited tightly. Game-details requests only count when
# they miss the cache (a cache hit makes no upstream call and is never limited),
# so this can be generous. Raise DETAILS_RATE_LIMIT_MAX if first-time loads of
# very large shared libraries get throttled.
SEARCH_RATE_LIMIT_MAX=10
DETAILS_RATE_LIMIT_MAX=300

# ── Cache ──────────────────────────────────────────────────────────────────────
# SQLite database file for the persistent cache. Set to empty to use an
# in-memory database (data is lost on restart).
CACHE_FILE=cache.db
#
# How long to cache each data type before re-fetching.
#
# Owned game libraries and player profiles — refreshed relatively often
# since users can buy new games or change their display name.
LIBRARY_CACHE_TTL_MINUTES=60
#
# Per-type TTLs for game details — these barely change, so long TTLs avoid
# hammering external APIs on every run.
#
# Steam ID → SteamID64 resolution (7 days)
RESOLVE_CACHE_TTL_MINUTES=10080
# Steam review scores (14 days)
RATING_CACHE_TTL_MINUTES=20160
# Store metadata, HLTB, tags (30 days)
META_CACHE_TTL_MINUTES=43200
